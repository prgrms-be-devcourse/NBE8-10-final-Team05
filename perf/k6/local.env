# 이 파일을 perf/k6/local.env로 복사해서 개인 로컬값을 넣는다.
# gitignore에 의해 커밋되지 않는다.
#
# 원칙
# - smoke의 가입/로그아웃 같은 검증 흐름을 깨는 ENABLE 토글은 여기서 덮어쓰지 않는다.
# - load/stress는 계정 풀과 시드 데이터만 채우고, 쓰기 비율은 도메인별 권장값으로 유지한다.
# - 더 좁은 튜닝이 필요하면 perf/k6/<domain>.env 또는 명령행 KEY=VALUE로 덮어쓴다.

# 공통
BASE_URL=http://localhost:8080

# auth 도메인
AUTH_THINK_SECONDS=0.2
AUTH_REFRESH_SHARE=0.2

# posts 도메인 권장값
POSTS_LIST_PAGE_SIZE=10
POSTS_FILTER_CATEGORY=WORRY
POSTS_DEEP_PAGE=10
POSTS_THINK_SECONDS=1
POSTS_WRITE_SHARE=0.05
POSTS_COMMENT_SHARE=0.35
POSTS_UPDATE_SHARE=0.5
POSTS_RESOLUTION_SHARE=0.35
POSTS_DELETE_SHARE=0.15
POSTS_COMMENT_DELETE_SHARE=0.2
POSTS_CREATE_CATEGORY=WORRY
POSTS_UPDATE_CATEGORY=DAILY

# letters 도메인 권장값
LETTERS_PAGE_SIZE=10
LETTERS_SENT_PAGE_SIZE=5
LETTERS_THINK_SECONDS=1
LETTERS_WRITE_SHARE=0.05
LETTERS_WRITING_STATUS_SHARE=0.15

# diary 도메인 권장값
DIARY_PAGE_SIZE=10
DIARY_THINK_SECONDS=1
DIARY_WRITE_SHARE=0.05
DIARY_UPDATE_SHARE=0.3
DIARY_UPDATE_IMAGE_SHARE=0.3
DIARY_DELETE_SHARE=0.1
DIARY_IMAGE_SHARE=0.5
DIARY_PRIVATE_RATE=0.5
DIARY_REQUIRE_USER_POOL=true
DIARY_CATEGORY_NAME=daily

# members 도메인 권장값
MEMBER_PROFILE_UPDATE_SHARE=0.15
MEMBER_RANDOM_SETTING_SHARE=0.2
MEMBER_EMAIL_UPDATE_SHARE=0.01

# reports 도메인 권장값
REPORT_TARGET_PAGE_SIZE=20
REPORTS_CREATE_SHARE=0.05
REPORT_TARGET_TYPE=POST
REPORT_REASON=SPAM
ADMIN_REPORT_NOTIFY=true
ADMIN_REPORT_ADMIN_COMMENT=k6-admin-comment
ADMIN_REPORT_NOTIFICATION_MESSAGE=k6-admin-action

# notifications 도메인 권장값
NOTIFICATIONS_READ_ROUNDS=1
NOTIFICATIONS_THINK_SECONDS=1

# auth load/stress용 계정 풀 예시
# AUTH_ACCESS_TOKENS=token1,token2,token3
# AUTH_CREDENTIALS_JSON='[{"email":"user1@example.com","password":"password1"},{"email":"user2@example.com","password":"password2"}]'

# 관리자 계정 예시
# ADMIN_ACCESS_TOKENS=admin-token1,admin-token2
# ADMIN_CREDENTIALS_JSON='[{"email":"admin@example.com","password":"password"}]'

# smoke/write 토글은 스크립트 기본값을 유지하려면 건드리지 않는다.
# 필요하면 별도 perf/k6/<domain>.env 파일이나 명령행에서만 덮어쓴다.
# POSTS_ENABLE_WRITE=false
# LETTERS_ENABLE_WRITE=false
# DIARY_ENABLE_WRITE=false
# MEMBER_ENABLE_WRITE=false
# REPORTS_ENABLE_CREATE=false

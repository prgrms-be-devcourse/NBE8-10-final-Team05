# =========================================================
# k6 클라우드 실행 환경 변수 템플릿
# - 팀원은 이 파일을 cloud.env로 복사해 값만 채우면 됩니다.
# - 형식: KEY = VALUE  (등호 앞뒤 공백 유지)
# - 백엔드는 배포 프로필(prod,k6)로 실행되어야
#   계정/시드 데이터가 자동 생성됩니다.
# =========================================================

# =========================================================
# 1) 필수 입력 (반드시 채워야 실행 가능)
# =========================================================

# 부하테스트 직접 대상 주소
# - load/stress는 공개 프록시 대신 직접 앱 포트(예: SSH 터널/사설망 경유)를 우선 사용합니다.
# - 예: http://127.0.0.1:18080
LOADTEST_BASE_URL =

# 공개 백엔드 API 주소 (예: https://api.maumon.com)
# - smoke, 수동 reset, 공개 경로 확인용
# - LOADTEST_BASE_URL이 비어 있으면 이 값을 부하테스트 대상으로 사용합니다.
BASE_URL = 

# =========================================================
# 2) 계정 풀 설정
# =========================================================

# 일반 사용자 계정 풀
AUTH_USER_PREFIX = k6-user
AUTH_USER_COUNT = 500
AUTH_USER_DOMAIN = k6.maumon.local

# 관리자 계정 풀
# - reports 도메인에서 ADMIN 권한 API 호출 시 사용
ADMIN_USER_PREFIX = k6-admin
ADMIN_USER_COUNT = 3
ADMIN_USER_DOMAIN = admin.maumon.local

# =========================================================
# 3) 공통 성능 기준값 (권장 기본값)
# =========================================================

# 요청 간 think time(초)
THINK_SECONDS = 1

# 허용 실패율 (0.01 = 1%)
FAIL_RATE = 0.01

# 공통 p95 목표(ms)
P95_MS = 1200

# =========================================================
# 4) 모드 수치 직접 오버라이드(보통 비움)
# - 비우면 스크립트 내부 도메인별 기본 시나리오 사용
# =========================================================
SMOKE_VUS = 1
SMOKE_ITERATIONS = 1
SMOKE_MAX_DURATION = 2m

LOAD_VUS = 
LOAD_DURATION = 

# 형식: target:duration,target:duration
# 예: 120:3m,240:7m,360:7m,0:3m
STRESS_STAGES = 

# =========================================================
# 5) 도메인별 write 스위치 (운영 안정성 위해 기본 false 권장)
# =========================================================
POSTS_ENABLE_WRITE = false
LETTERS_ENABLE_WRITE = false
DIARY_ENABLE_WRITE = false
MEMBERS_ENABLE_WRITE = false
REPORTS_ENABLE_CREATE = false

# =========================================================
# 6) 도메인별 세부 옵션 (필요할 때만 수정)
# =========================================================

# auth
AUTH_ENABLE_LOGOUT = false
AUTH_REFRESH_SHARE = 0.30

# posts / letters / diary / members / reports
POSTS_WRITE_SHARE = 0.30
LETTERS_WRITE_SHARE = 0.25
DIARY_WRITE_SHARE = 0.15
MEMBERS_WRITE_SHARE = 0.25
REPORTS_CREATE_SHARE = 0.25

# letters
LETTERS_ENABLE_ACCEPT = false

# diary
DIARY_PUBLIC_SHARE = 0.70
DIARY_DELETE_AFTER_WRITE = false

# members
MEMBERS_ENABLE_EMAIL_UPDATE = false

# reports
# 신고 사유: PROFANITY | SPAM | INAPPROPRIATE | PERSONAL_INFO | OTHER
REPORTS_REASON = SPAM

# 관리자 처리 액션: NONE | REJECT | DELETE | BLOCK_USER
ADMIN_REPORT_HANDLE_ACTION = NONE
ADMIN_REPORT_ADMIN_COMMENT = k6-admin-comment
ADMIN_REPORT_NOTIFY = false
ADMIN_REPORT_NOTIFICATION_MESSAGE = 

# notifications
NOTIFICATIONS_READ_ROUNDS = 2

# =========================================================
# 7) 참고 실행 예시
# =========================================================
# node perf/k6/run.mjs auth smoke
# node perf/k6/run.mjs posts load
# node perf/k6/run.mjs posts stress

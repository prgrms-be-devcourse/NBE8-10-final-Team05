{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Row 1: Overall Health (K6 vs Backend)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "reqps" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(rate(k6_http_reqs_total{testid=~\"${testid:regex}\"}[$__rate_interval]))", "refId": "A" }
      ],
      "title": "K6 총 요청량 (RPS)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "percent", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "avg(k6_http_req_failed_rate{testid=~\"${testid:regex}\"}) * 100", "refId": "A" }
      ],
      "title": "K6 에러율 (%)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "ms" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "avg(k6_http_req_duration_p95{testid=~\"${testid:regex}\"})", "refId": "A" }
      ],
      "title": "K6 p95 응답시간",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "max(k6_vus{testid=~\"${testid:regex}\"})", "refId": "A" }
      ],
      "title": "현재 VU (가상유저)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "id": 6,
      "title": "응답 시간 비교 (K6 vs 백엔드 내부)",
      "type": "timeseries",
      "options": { "legend": { "displayMode": "list", "placement": "right" } },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        { "expr": "avg(k6_http_req_duration_p95{testid=~\"${testid:regex}\"})", "legendFormat": "K6 p95", "refId": "A" },
        { "expr": "avg(http_server_requests_seconds_max * 1000)", "legendFormat": "Backend Max (API)", "refId": "B" }
      ]
    },
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 200,
      "title": "Row 2: Backend Saturation (실제 병목 관찰)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 7,
      "title": "Tomcat 쓰레드 포화도 (Threads)",
      "type": "timeseries",
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        { "expr": "tomcat_threads_active_threads", "legendFormat": "Active Threads", "refId": "A" },
        { "expr": "tomcat_threads_config_max_threads", "legendFormat": "Max Threads", "refId": "B" },
        { "expr": "tomcat_threads_current_threads", "legendFormat": "Current Threads", "refId": "C" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 8,
      "title": "DB 커넥션 상태 (HikariCP)",
      "type": "timeseries",
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        { "expr": "hikaricp_connections_active", "legendFormat": "Active Connections", "refId": "A" },
        { "expr": "hikaricp_connections_pending", "legendFormat": "Pending (대기 중)", "refId": "B" },
        { "expr": "hikaricp_connections_idle", "legendFormat": "Idle Connections", "refId": "C" }
      ]
    },
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 300,
      "title": "Row 3: JVM & System Resources",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 9,
      "title": "JVM Heap 메모리 및 GC",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "decbytes" } },
      "targets": [
        { "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})", "legendFormat": "Used Heap", "refId": "A" },
        { "expr": "sum(jvm_memory_max_bytes{area=\"heap\"})", "legendFormat": "Max Heap", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 10,
      "title": "시스템 부하 (CPU & Threads)",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        { "expr": "system_cpu_usage", "legendFormat": "System CPU", "refId": "A" },
        { "expr": "process_cpu_usage", "legendFormat": "Process CPU", "refId": "B" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["k6", "loadtest", "performance"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(k6_http_reqs_total, testid)",
        "hide": 0,
        "includeAll": true,
        "label": "K6 Test ID",
        "multi": true,
        "name": "testid",
        "options": [],
        "query": { "query": "label_values(k6_http_reqs_total, testid)", "refId": "StandardVariableQuery" },
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 0,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "Maum-On K6 Bottleneck Dashboard",
  "uid": "maum-on-k6-load-test",
  "version": 2
}

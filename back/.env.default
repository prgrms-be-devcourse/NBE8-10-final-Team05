# =========================
# Database (dev/test)
# =========================
DEV_DB_URL=jdbc:postgresql://localhost:5432/maum_on_dev
DEV_DB_USERNAME=maum_on
DEV_DB_PASSWORD=maum_on

# =========================
# Database (prod)
# =========================
PROD_DB_URL=jdbc:postgresql://localhost:5432/maum_on_prod
PROD_DB_USERNAME=maum_on
PROD_DB_PASSWORD=maum_on

# =========================
# JWT
# =========================
JWT_ISSUER=maum-on
JWT_SECRET_KEY=replace-with-at-least-32-characters-secret
JWT_ACCESS_TOKEN_EXPIRE_SECONDS=3600
JWT_REFRESH_TOKEN_EXPIRE_SECONDS=1209600
JWT_REFRESH_TOKEN_COOKIE_NAME=refreshToken
JWT_REFRESH_TOKEN_COOKIE_SECURE=false
JWT_REFRESH_TOKEN_COOKIE_SAME_SITE=Lax

# =========================
# Google OIDC
# =========================
OIDC_ISSUER_URI=https://accounts.google.com
OIDC_USER_NAME_ATTRIBUTE=sub
OIDC_CLIENT_ID=replace-with-google-client-id
OIDC_CLIENT_SECRET=replace-with-google-client-secret

# =========================
# Kakao OIDC
# =========================
KAKAO_CLIENT_ID=replace-with-kakao-client-id
KAKAO_CLIENT_SECRET=replace-with-kakao-client-secret

# =========================
# Gemini API
# =========================
GOOGLE_API_KEY=replace-with-gemini-api-key

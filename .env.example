# =========================
# 공통/백엔드 (deploy-backend.yml 의 DOT_ENV에 그대로 저장)
# =========================
PROD_DB_URL=jdbc:postgresql://postgres:5432/maum_on_prod
PROD_DB_USERNAME=maum_on
PROD_DB_PASSWORD=change-me
PROD_REDIS_URL=redis
PROD_REDIS_PASSWORD=

JWT_SECRET_KEY=change-me-at-least-32-chars
JWT_ISSUER=maum-on
JWT_REFRESH_TOKEN_COOKIE_DOMAIN=.maum-on.parksuyeon.site
JWT_REFRESH_TOKEN_COOKIE_SECURE=true
JWT_REFRESH_TOKEN_COOKIE_SAME_SITE=None

GOOGLE_OIDC_ISSUER_URI=https://accounts.google.com
GOOGLE_OIDC_CLIENT_ID=change-me
GOOGLE_OIDC_CLIENT_SECRET=change-me
KAKAO_CLIENT_ID=change-me
KAKAO_CLIENT_SECRET=change-me
GOOGLE_API_KEY=change-me

FRONTEND_ALLOWED_ORIGIN_PATTERNS=https://maum-on.parksuyeon.site,https://www.maum-on.parksuyeon.site,https://*.vercel.app
AUTH_OIDC_REDIRECT_URI_ALLOWLIST_1=https://maum-on.parksuyeon.site
AUTH_OIDC_REDIRECT_URI_ALLOWLIST_2=https://www.maum-on.parksuyeon.site
# OIDC redirect allowlist는 wildcard host를 지원하지 않으므로 Vercel preview 도메인은 개별 등록 전까지 로그인 콜백에 사용할 수 없습니다.
CUSTOM_FILE_UPLOAD_DIR=/app/uploads
S3_BUCKET=change-me
S3_REGION=ap-northeast-2
S3_PREFIX=maum-on
S3_PUBLIC_BASE_URL=

# =========================
# 모니터링 (deploy-monitoring.yml 의 DOT_ENV에 그대로 저장)
# =========================
BACKEND_SCRAPE_TARGET=maum-on-backend-prod:8080
PROMETHEUS_EXTERNAL_URL=http://127.0.0.1:9090/

GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me
GF_SERVER_ROOT_URL=http://127.0.0.1:3000/

# =========================
# 배포 compose에서 워크플로우가 동적으로 추가하는 항목
# (수동 작성 불필요)
# GHCR_IMAGE=
# IMAGE_TAG=
# APP_PORT=
# =========================

# Spring 프로필
# - 기본값은 prod
# - 부하테스트 환경에서는 DOT_ENV에 아래처럼 덮어쓰기: SPRING_PROFILES_ACTIVE=prod,k6
SPRING_PROFILES_ACTIVE=prod

# =========================
# GitHub Actions Secrets (deploy-backend.yml에서 사용)
# 리포지토리/환경 Secret으로 등록 권장
# =========================
API_PROXY_DOMAIN=api.maum-on.parksuyeon.site
NPM_BASE_URL=https://127.0.0.1:81
NPM_ADMIN_PASSWORD=change-me

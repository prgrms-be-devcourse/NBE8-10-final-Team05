# =========================
# 공통/백엔드 (deploy-backend.yml 의 DOT_ENV에 그대로 저장)
# =========================
PROD_DB_URL=jdbc:postgresql://postgres:5432/maum_on_prod
PROD_DB_USERNAME=maum_on
PROD_DB_PASSWORD=change-me
PROD_REDIS_URL=redis
PROD_REDIS_PASSWORD=

JWT_SECRET_KEY=change-me-at-least-32-chars
JWT_ISSUER=maum-on
JWT_REFRESH_TOKEN_COOKIE_DOMAIN=.example.com
JWT_REFRESH_TOKEN_COOKIE_SECURE=true
JWT_REFRESH_TOKEN_COOKIE_SAME_SITE=None

GOOGLE_OIDC_ISSUER_URI=https://accounts.google.com
GOOGLE_OIDC_CLIENT_ID=change-me
GOOGLE_OIDC_CLIENT_SECRET=change-me
KAKAO_CLIENT_ID=change-me
KAKAO_CLIENT_SECRET=change-me
GOOGLE_API_KEY=change-me

FRONTEND_ALLOWED_ORIGIN_PATTERNS=https://your-frontend.vercel.app
CUSTOM_FILE_UPLOAD_DIR=/app/uploads
S3_BUCKET=change-me
S3_REGION=ap-northeast-2
S3_PREFIX=maum-on
S3_PUBLIC_BASE_URL=

# =========================
# 모니터링 (deploy-monitoring.yml 의 DOT_ENV에 그대로 저장)
# =========================
BACKEND_SCRAPE_TARGET=maum-on-backend-prod:8080
PROMETHEUS_EXTERNAL_URL=https://monitor.example.com/prometheus/

GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me
GF_SERVER_ROOT_URL=https://monitor.example.com/

# =========================
